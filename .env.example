# Required in production — generate with: openssl rand -base64 32
JWT_SECRET=

# Admin seed account password — set before first launch
# Defaults to 'admin-dev' in development (prints a warning if unset)
ADMIN_PASSWORD=

# Platform fee taken from the pot at settlement (default 5%)
FEE_RATE=0.05

# Optional
PORT=3000
HOST=0.0.0.0
DB_PATH=rapidclash.db
